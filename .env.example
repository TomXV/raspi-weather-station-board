# DeepL Free API key (https://www.deepl.com/pro-api)
DEEPL_API_KEY=your-deepl-api-key-here

# Optional: absolute path to node-edge-tts bin.js
# If omitted, scripts auto-discover common install paths.
# EDGE_TTS_BIN=/home/your-user/.bun/install/global/node_modules/node-edge-tts/bin.js

# Optional: skip ffplay audio output when set to 1.
# NO_PLAY=1
